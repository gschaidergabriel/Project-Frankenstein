# ============================================================
# Project Frankenstein (F.R.A.N.K.) — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables are optional — sensible defaults are used when unset.

# --- Anthropic API (for UI tester only) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google OAuth2 (for Gmail integration) ---
# Default: Thunderbird's public OAuth2 credentials (safe to use)
# Override only if you have your own Google OAuth app
# FRANK_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# FRANK_GOOGLE_CLIENT_SECRET=your-client-secret

# --- Service Ports (all default to localhost) ---
# AICORE_CORE_URL=http://127.0.0.1:9000
# AICORE_ROUTER_URL=http://127.0.0.1:8091
# AICORE_WEBD_SEARCH_URL=http://127.0.0.1:8093/search
# AICORE_WEBD_FETCH_URL=http://127.0.0.1:8093/fetch
# AICORE_WEBD_RSS_URL=http://127.0.0.1:8093/rss
# AICORE_WEBD_NEWS_URL=http://127.0.0.1:8093/news
# AICORE_WEBD_DARKNET_URL=http://127.0.0.1:8093/darknet
# AICORE_DESKTOP_ACTION_URL=http://127.0.0.1:8092/desktop/action
# AICORE_TOOLBOX_BASE=http://127.0.0.1:8096

# --- Paths (auto-detected from config.paths, override if needed) ---
# AICORE_ROOT=/path/to/aicore
# AICORE_TEMP_DIR=/tmp/frank
