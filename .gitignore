# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.eggs/
build/

# Dist (PyInstaller output) — keep the installer binary
dist/*
!dist/frank-installer
!dist/frank-recovery
venv/
.venv/

# Databases — runtime WAL/SHM/journal never committed
*.db-shm
*.db-wal
*.db-journal
*.db.backup

# Exception: reference databases for recovery tool
!database/
!database/*.db
!database/*.sqlite
!database/*.json
!database/*.npz
!database/invariants/

# Block .db files everywhere EXCEPT database/ dir
# (prevents accidental commit of live DBs from other dirs)
*.db
*.sqlite
*.sqlite3
!database/**

# Runtime state
*.lock
*.pid
logs/

# Environment and secrets
.env
*.secret
*.key
*.pem
credentials/
tokens/

# User configuration (generated, may contain personal data)
gateway/config.json
configs/paths.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test artifacts
tests/consciousness_results.jsonl
tests/consciousness_report.md
tests/consciousness_audit_v2.md

# Sandbox / training artifacts
sandbox/

# Screenshots
screenshot.png
error_screenshots/

# Vector data (generated, except in database/)
*_vectors.npz
*_vector_ids.json
!database/*_vectors.npz
!database/*_vector_ids.json

# Temporary files
/tmp/

# Models (too large for git, downloaded by install.sh)
*.gguf
models/

# Voice models
voices/

# ASRS backups (generated)
asrs_backups/

# ADI profiles (user-specific)
adi_profiles/

# Test screenshots and reports (generated)
tests/ui test/screenshots/
tests/ui test/reports/
tests/ui test/baseline/

# System info (machine-specific)
system_info.json
database/invariants/*.db-shm
database/invariants/*.db-wal
